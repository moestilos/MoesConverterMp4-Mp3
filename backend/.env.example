# Server
PORT=4000

# CORS - origen(es) del frontend. Lista separada por comas.
CORS_ORIGIN=http://localhost:4321

# Tamano maximo de archivo en bytes (default 1 GB)
MAX_FILE_SIZE=1073741824

# TTL de archivos temporales en milisegundos (default 15 min)
FILE_TTL_MS=900000

# Ruta opcional al binario de ffmpeg (si no esta en PATH)
# FFMPEG_PATH=C:/ffmpeg/bin/ffmpeg.exe

# Groq API key para transcripcion con Whisper Large v3 Turbo (gratis en console.groq.com)
GROQ_API_KEY=
