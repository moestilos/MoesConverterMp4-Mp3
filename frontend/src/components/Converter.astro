---
const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:4000';
const maxMb = 100;
---

<section
  id="converter"
  class="glass rounded-3xl p-6 sm:p-10 shadow-card"
  data-api-url={apiUrl}
  data-max-mb={maxMb}
>
  <!-- Stage: IDLE (dropzone) -->
  <div data-stage="idle">
    <label
      id="dropzone"
      for="file-input"
      class="dropzone group"
      tabindex="0"
      role="button"
      aria-label="Seleccionar o soltar archivo MP4"
    >
      <div
        class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity"
        style="background: radial-gradient(600px circle at var(--x,50%) var(--y,50%), rgba(139,92,246,0.15), transparent 40%);"
        id="dropzone-spotlight"
        aria-hidden="true"
      ></div>

      <div class="relative flex flex-col items-center text-center">
        <div
          class="w-20 h-20 rounded-2xl grid place-items-center mb-6
                 bg-gradient-to-br from-brand-500/30 to-accent-500/30
                 border border-white/10 animate-float-med shadow-glow"
        >
          <svg class="w-9 h-9 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3v12" />
            <path d="m7 8 5-5 5 5" />
            <path d="M5 21h14" />
          </svg>
        </div>

        <h3 class="text-xl sm:text-2xl font-semibold text-white mb-2">
          Arrastra tu video aquí
        </h3>
        <p class="text-slate-400 mb-5 max-w-md">
          o haz clic para seleccionar. MP4, MOV, WebM, AVI…
          <span class="text-slate-500">hasta {maxMb} MB.</span>
        </p>
        <span class="btn-ghost text-sm pointer-events-none">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
            <polyline points="17 8 12 3 7 8" />
            <line x1="12" y1="3" x2="12" y2="15" />
          </svg>
          Seleccionar archivo
        </span>
      </div>

      <input id="file-input" type="file" accept="video/*" class="hidden" />
    </label>

    <div class="mt-6 grid grid-cols-1 sm:grid-cols-3 gap-3 text-sm">
      <div class="glass rounded-xl p-4 flex items-center gap-3">
        <span class="w-8 h-8 rounded-lg bg-brand-500/20 text-brand-300 grid place-items-center">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2 3 14h7l-1 8 10-12h-7z"/></svg>
        </span>
        <div>
          <p class="text-white font-medium">Rápido</p>
          <p class="text-slate-400 text-xs">FFmpeg nativo</p>
        </div>
      </div>
      <div class="glass rounded-xl p-4 flex items-center gap-3">
        <span class="w-8 h-8 rounded-lg bg-accent-500/20 text-accent-400 grid place-items-center">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </span>
        <div>
          <p class="text-white font-medium">Privado</p>
          <p class="text-slate-400 text-xs">Archivos se auto-eliminan</p>
        </div>
      </div>
      <div class="glass rounded-xl p-4 flex items-center gap-3">
        <span class="w-8 h-8 rounded-lg bg-emerald-500/20 text-emerald-300 grid place-items-center">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg>
        </span>
        <div>
          <p class="text-white font-medium">Sin registro</p>
          <p class="text-slate-400 text-xs">Sube y descarga</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Stage: FILE READY -->
  <div data-stage="ready" class="hidden">
    <div class="flex items-start gap-4">
      <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-brand-500/30 to-accent-500/30 border border-white/10 grid place-items-center shrink-0">
        <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="m15 10 5 5V5l-5 5z"/><rect x="3" y="6" width="12" height="12" rx="2"/></svg>
      </div>
      <div class="min-w-0 flex-1">
        <p class="text-xs uppercase tracking-wider text-slate-400">Archivo seleccionado</p>
        <p id="file-name" class="text-lg font-semibold text-white truncate"></p>
        <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-slate-400 mt-1">
          <span id="file-size"></span>
          <span id="file-duration"></span>
        </div>
      </div>
      <button type="button" id="btn-cancel" class="btn-ghost text-sm" aria-label="Cambiar archivo">
        Cambiar
      </button>
    </div>

    <div class="mt-6">
      <label for="output-name" class="block text-sm text-slate-300 mb-2">
        Nombre de salida
      </label>
      <div class="flex items-stretch rounded-xl border border-white/10 bg-white/[0.03] focus-within:border-accent-400/60 transition-colors">
        <input
          id="output-name"
          type="text"
          class="flex-1 bg-transparent px-4 py-3 text-white outline-none"
          placeholder="mi-audio"
          autocomplete="off"
        />
        <span class="px-4 py-3 text-slate-500 text-sm select-none border-l border-white/10">.mp3</span>
      </div>
    </div>

    <div class="mt-6 flex flex-col sm:flex-row gap-3">
      <button id="btn-convert" type="button" class="btn-primary flex-1">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3v18l15-9z"/></svg>
        Convertir a MP3
      </button>
      <button id="btn-cancel-2" type="button" class="btn-ghost">
        Cancelar
      </button>
    </div>
  </div>

  <!-- Stage: PROGRESS -->
  <div data-stage="progress" class="hidden">
    <div class="flex items-center gap-4 mb-8">
      <div class="relative w-14 h-14 shrink-0">
        <div class="absolute inset-0 rounded-full bg-accent-500/20 animate-pulse-glow"></div>
        <div class="absolute inset-0 rounded-full border-2 border-accent-400/60 border-t-transparent animate-spin"></div>
      </div>
      <div class="min-w-0 flex-1">
        <p id="progress-label" class="text-white font-semibold">Subiendo archivo…</p>
        <p id="progress-sub" class="text-slate-400 text-sm truncate">Preparando la conversión</p>
      </div>
      <span id="progress-percent" class="font-mono text-2xl font-semibold text-white tabular-nums">0%</span>
    </div>

    <div class="progress-track">
      <div id="progress-bar" class="progress-bar" style="width: 0%"></div>
    </div>

    <div class="mt-4 flex items-center justify-between text-xs text-slate-500">
      <span id="progress-stage">Fase 1 de 2 · Subida</span>
      <span>FFmpeg · libmp3lame · 192 kbps</span>
    </div>
  </div>

  <!-- Stage: DONE -->
  <div data-stage="done" class="hidden">
    <div class="flex flex-col items-center text-center py-6">
      <div class="w-20 h-20 rounded-2xl bg-emerald-500/20 border border-emerald-400/30 grid place-items-center mb-5 shadow-[0_0_40px_-8px_rgba(16,185,129,0.55)]">
        <svg class="w-9 h-9 text-emerald-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </div>
      <h3 class="text-2xl font-bold text-white mb-2">¡Listo!</h3>
      <p class="text-slate-400 mb-6">Tu MP3 está preparado para descargar.</p>
      <div class="flex flex-col sm:flex-row gap-3 w-full sm:w-auto">
        <button id="btn-download" type="button" class="btn-primary">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Descargar MP3
        </button>
        <button id="btn-again" type="button" class="btn-ghost">
          Convertir otro
        </button>
      </div>
    </div>
  </div>

  <!-- Stage: ERROR -->
  <div data-stage="error" class="hidden">
    <div class="flex flex-col items-center text-center py-6">
      <div class="w-20 h-20 rounded-2xl bg-rose-500/20 border border-rose-400/30 grid place-items-center mb-5">
        <svg class="w-9 h-9 text-rose-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      </div>
      <h3 class="text-2xl font-bold text-white mb-2">Algo salió mal</h3>
      <p id="error-msg" class="text-rose-200/80 mb-6 max-w-md">Error desconocido.</p>
      <button id="btn-retry" type="button" class="btn-primary">
        Intentar de nuevo
      </button>
    </div>
  </div>
</section>

<script>
  import { initConverter } from '../scripts/converter';
  initConverter();
</script>
