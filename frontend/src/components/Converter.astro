---
const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:4000';
const maxMb = 1024;
const maxLabel = maxMb >= 1024 ? `${maxMb / 1024} GB` : `${maxMb} MB`;
---

<section
  id="converter"
  class="glass rounded-3xl p-5 sm:p-8 lg:p-10 shadow-card"
  data-api-url={apiUrl}
  data-max-mb={maxMb}
  data-max-label={maxLabel}
>
  <!-- Stage: IDLE (dropzone) -->
  <div data-stage="idle">
    <label
      id="dropzone"
      for="file-input"
      class="dropzone group"
      tabindex="0"
      role="button"
      aria-label="Seleccionar o soltar archivo MP4"
    >
      <div
        class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity"
        style="background: radial-gradient(600px circle at var(--x,50%) var(--y,50%), rgba(139,92,246,0.15), transparent 40%);"
        id="dropzone-spotlight"
        aria-hidden="true"
      ></div>

      <div class="relative flex flex-col items-center text-center">
        <div
          class="w-16 h-16 sm:w-20 sm:h-20 rounded-2xl grid place-items-center mb-5 sm:mb-6
                 bg-gradient-to-br from-brand-500/30 to-accent-500/30
                 border border-white/10 animate-float-med shadow-glow"
        >
          <svg class="w-8 h-8 sm:w-9 sm:h-9 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3v12" />
            <path d="m7 8 5-5 5 5" />
            <path d="M5 21h14" />
          </svg>
        </div>

        <h3 class="text-lg sm:text-xl md:text-2xl font-semibold text-white mb-2">
          Arrastra tu video o audio
        </h3>
        <p class="text-slate-400 mb-5 max-w-md text-sm sm:text-base">
          MP4, MOV, WebM, MP3, WAV, M4A…
          <span class="text-slate-500">hasta {maxLabel}.</span>
        </p>
        <span class="btn-ghost text-sm pointer-events-none">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
            <polyline points="17 8 12 3 7 8" />
            <line x1="12" y1="3" x2="12" y2="15" />
          </svg>
          Seleccionar archivo
        </span>
      </div>

      <input id="file-input" type="file" accept="video/*,audio/*" class="hidden" />
    </label>

    <div class="mt-6 grid grid-cols-1 sm:grid-cols-3 gap-3 text-sm">
      <div class="glass rounded-xl p-4 flex items-center gap-3">
        <span class="w-8 h-8 rounded-lg bg-brand-500/20 text-brand-300 grid place-items-center">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2 3 14h7l-1 8 10-12h-7z"/></svg>
        </span>
        <div>
          <p class="text-white font-medium">MP4 → MP3</p>
          <p class="text-slate-400 text-xs">FFmpeg nativo</p>
        </div>
      </div>
      <div class="glass rounded-xl p-4 flex items-center gap-3">
        <span class="w-8 h-8 rounded-lg bg-accent-500/20 text-accent-400 grid place-items-center">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h10"/></svg>
        </span>
        <div>
          <p class="text-white font-medium">Audio → Texto</p>
          <p class="text-slate-400 text-xs">Whisper Large v3 · Groq</p>
        </div>
      </div>
      <div class="glass rounded-xl p-4 flex items-center gap-3">
        <span class="w-8 h-8 rounded-lg bg-emerald-500/20 text-emerald-300 grid place-items-center">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </span>
        <div>
          <p class="text-white font-medium">100% privado</p>
          <p class="text-slate-400 text-xs">Sin registro, auto-borrado</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Stage: FILE READY -->
  <div data-stage="ready" class="hidden">
    <div class="flex items-start gap-3 sm:gap-4">
      <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-xl bg-gradient-to-br from-brand-500/30 to-accent-500/30 border border-white/10 grid place-items-center shrink-0">
        <svg class="w-5 h-5 sm:w-6 sm:h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="m15 10 5 5V5l-5 5z"/><rect x="3" y="6" width="12" height="12" rx="2"/></svg>
      </div>
      <div class="min-w-0 flex-1">
        <p class="text-xs uppercase tracking-wider text-slate-400">Archivo seleccionado</p>
        <p id="file-name" class="text-base sm:text-lg font-semibold text-white truncate"></p>
        <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs sm:text-sm text-slate-400 mt-1">
          <span id="file-size"></span>
          <span id="file-duration"></span>
        </div>
      </div>
      <button type="button" id="btn-cancel" class="btn-ghost text-sm" aria-label="Cambiar archivo">
        Cambiar
      </button>
    </div>

    <div class="mt-5 sm:mt-6">
      <label for="output-name" class="block text-sm text-slate-300 mb-2">
        Nombre de salida
      </label>
      <div class="flex items-stretch rounded-xl border border-white/10 bg-white/[0.03] focus-within:border-accent-400/60 transition-colors">
        <input
          id="output-name"
          type="text"
          class="flex-1 bg-transparent px-4 py-3 text-white outline-none min-w-0"
          placeholder="mi-audio"
          autocomplete="off"
        />
        <span class="px-3 sm:px-4 py-3 text-slate-500 text-sm select-none border-l border-white/10">.mp3</span>
      </div>
    </div>

    <div id="upload-status" class="mt-5 sm:mt-6 hidden">
      <div class="flex items-center justify-between text-sm mb-2">
        <span id="upload-label" class="text-slate-300">Subiendo archivo…</span>
        <span id="upload-percent" class="font-mono text-slate-200 tabular-nums">0%</span>
      </div>
      <div class="progress-track">
        <div id="upload-bar" class="progress-bar" style="width: 0%"></div>
      </div>
      <p id="upload-sub" class="mt-2 text-xs text-slate-500"></p>
    </div>

    <div class="mt-5 sm:mt-6 flex flex-col sm:flex-row gap-3">
      <button id="btn-convert" type="button" class="btn-primary flex-1" disabled>
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3v18l15-9z"/></svg>
        <span id="btn-convert-label">Subiendo…</span>
      </button>
      <button id="btn-cancel-2" type="button" class="btn-ghost">
        Cancelar
      </button>
    </div>
  </div>

  <!-- Stage: PROGRESS (conversion) -->
  <div data-stage="progress" class="hidden">
    <div class="flex items-center gap-3 sm:gap-4 mb-6 sm:mb-8">
      <div class="relative w-12 h-12 sm:w-14 sm:h-14 shrink-0">
        <div class="absolute inset-0 rounded-full bg-accent-500/20 animate-pulse-glow"></div>
        <div class="absolute inset-0 rounded-full border-2 border-accent-400/60 border-t-transparent animate-spin"></div>
      </div>
      <div class="min-w-0 flex-1">
        <p id="progress-label" class="text-white font-semibold text-sm sm:text-base">Convirtiendo a MP3…</p>
        <p id="progress-sub" class="text-slate-400 text-xs sm:text-sm truncate">Iniciando FFmpeg</p>
      </div>
      <span id="progress-percent" class="font-mono text-xl sm:text-2xl font-semibold text-white tabular-nums">0%</span>
    </div>

    <div class="progress-track">
      <div id="progress-bar" class="progress-bar" style="width: 0%"></div>
    </div>

    <div class="mt-4 flex items-center justify-between text-xs text-slate-500 gap-3">
      <span id="progress-stage" class="truncate">Conversión en curso</span>
      <span class="shrink-0 hidden sm:inline">FFmpeg · libmp3lame · 192 kbps</span>
    </div>
  </div>

  <!-- Stage: DONE -->
  <div data-stage="done" class="hidden">
    <div class="flex flex-col items-center text-center py-4 sm:py-6">
      <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-2xl bg-emerald-500/20 border border-emerald-400/30 grid place-items-center mb-4 sm:mb-5 shadow-[0_0_40px_-8px_rgba(16,185,129,0.55)]">
        <svg class="w-8 h-8 sm:w-9 sm:h-9 text-emerald-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </div>
      <h3 class="text-xl sm:text-2xl font-bold text-white mb-2">¡Listo!</h3>
      <p id="done-sub" class="text-slate-400 mb-5 sm:mb-6 text-sm sm:text-base">Tu MP3 está preparado.</p>

      <!-- Audio player preview -->
      <div id="audio-preview" class="hidden w-full max-w-md mb-5 sm:mb-6">
        <div class="glass rounded-2xl p-3 sm:p-4 flex items-center gap-3">
          <button id="btn-play" type="button"
                  class="w-11 h-11 shrink-0 rounded-full bg-gradient-to-br from-brand-500 to-accent-500
                         grid place-items-center text-white shadow-glow
                         hover:scale-105 active:scale-95 transition-transform"
                  aria-label="Reproducir">
            <svg id="icon-play" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            <svg id="icon-pause" class="hidden w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M6 4h4v16H6zM14 4h4v16h-4z"/></svg>
          </button>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1 text-xs text-slate-400 tabular-nums">
              <span id="audio-time">0:00</span>
              <span class="flex-1"></span>
              <span id="audio-total">0:00</span>
            </div>
            <input id="audio-seek" type="range" min="0" max="100" step="0.1" value="0"
                   class="w-full accent-accent-500 cursor-pointer"
                   aria-label="Posición reproducción" />
          </div>
          <audio id="audio-el" preload="metadata" class="hidden"></audio>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-3 w-full sm:w-auto">
        <button id="btn-download" type="button" class="btn-primary">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          <span id="btn-download-label">Descargar MP3</span>
        </button>
        <button id="btn-again" type="button" class="btn-ghost">
          Convertir otro
        </button>
      </div>
    </div>

    <!-- Transcription section -->
    <div class="mt-8 pt-6 border-t border-white/10">
      <div class="flex items-start gap-3 mb-4">
        <div class="w-10 h-10 rounded-xl bg-accent-500/20 border border-accent-400/20 grid place-items-center shrink-0">
          <svg class="w-5 h-5 text-accent-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h10"/></svg>
        </div>
        <div class="min-w-0 flex-1">
          <h4 class="text-white font-semibold">Transcribir a texto</h4>
          <p class="text-slate-400 text-xs sm:text-sm">
            Whisper Large v3 Turbo vía <strong class="text-slate-200">Groq</strong>.
            Resultado en ~20 segundos. Soporta +50 idiomas.
          </p>
        </div>
      </div>

      <div class="mb-4">
        <label for="whisper-lang" class="block text-xs text-slate-400 mb-1">Idioma del audio</label>
        <select
          id="whisper-lang"
          class="w-full bg-white/[0.03] border border-white/10 rounded-xl px-3 py-2.5 text-white text-sm outline-none focus:border-accent-400/60"
        >
          <option value="">Auto-detectar</option>
          <option value="es" selected>Español</option>
          <option value="en">Inglés</option>
          <option value="fr">Francés</option>
          <option value="de">Alemán</option>
          <option value="it">Italiano</option>
          <option value="pt">Portugués</option>
          <option value="ca">Catalán</option>
          <option value="ja">Japonés</option>
          <option value="zh">Chino</option>
          <option value="ar">Árabe</option>
          <option value="ru">Ruso</option>
          <option value="nl">Holandés</option>
          <option value="pl">Polaco</option>
          <option value="tr">Turco</option>
          <option value="ko">Coreano</option>
        </select>
      </div>

      <button id="btn-transcribe" type="button" class="btn-primary w-full">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 3v4a1 1 0 0 0 1 1h4"/><path d="M17 21H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7l5 5v11a2 2 0 0 1-2 2z"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="13" y2="17"/></svg>
        Transcribir audio
      </button>
    </div>
  </div>

  <!-- Stage: TRANSCRIBING -->
  <div data-stage="transcribing" class="hidden">
    <div class="flex items-center gap-3 sm:gap-4 mb-6">
      <div class="relative w-12 h-12 sm:w-14 sm:h-14 shrink-0">
        <div class="absolute inset-0 rounded-full bg-accent-500/20 animate-pulse-glow"></div>
        <div class="absolute inset-0 rounded-full border-2 border-accent-400/60 border-t-transparent animate-spin"></div>
      </div>
      <div class="min-w-0 flex-1">
        <p id="trans-label" class="text-white font-semibold text-sm sm:text-base">Descargando modelo…</p>
        <p id="trans-sub" class="text-slate-400 text-xs sm:text-sm truncate">Una sola vez — se cachea en tu navegador</p>
      </div>
      <span id="trans-percent" class="font-mono text-lg sm:text-2xl font-semibold text-white tabular-nums">—</span>
    </div>

    <div class="progress-track">
      <div id="trans-bar" class="progress-bar" style="width: 0%"></div>
    </div>

    <div class="mt-4 flex items-center justify-between text-xs text-slate-500 gap-3">
      <span id="trans-stage" class="truncate">Preparando Whisper…</span>
      <button id="btn-trans-cancel" type="button" class="text-rose-300 hover:text-rose-200 shrink-0">Cancelar</button>
    </div>
  </div>

  <!-- Stage: TRANSCRIPT -->
  <div data-stage="transcript" class="hidden">
    <div class="flex items-start gap-3 mb-4">
      <div class="w-10 h-10 rounded-xl bg-emerald-500/20 border border-emerald-400/30 grid place-items-center shrink-0">
        <svg class="w-5 h-5 text-emerald-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <div class="min-w-0 flex-1">
        <h4 class="text-white font-semibold text-base sm:text-lg">Transcripción lista</h4>
        <p class="text-slate-400 text-xs sm:text-sm" id="trans-meta">—</p>
      </div>
    </div>

    <textarea
      id="transcript-text"
      class="w-full h-56 sm:h-72 bg-white/[0.03] border border-white/10 rounded-xl p-4 text-slate-100 text-sm leading-relaxed outline-none focus:border-accent-400/60 resize-y"
      readonly
    ></textarea>

    <div class="mt-4 flex flex-wrap gap-2">
      <button id="btn-copy-text" type="button" class="btn-ghost text-sm flex-1 sm:flex-none">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        <span>Copiar</span>
      </button>

      <!-- Dropdown export -->
      <div class="relative flex-1 sm:flex-none">
        <button id="btn-export-toggle" type="button" class="btn-ghost text-sm w-full">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          <span>Exportar</span>
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div id="export-menu"
             class="hidden absolute right-0 mt-1 min-w-[200px] z-20
                    bg-[#0f0f1a] border border-white/10 rounded-xl
                    shadow-[0_20px_60px_-20px_rgba(0,0,0,0.9)]
                    overflow-hidden">
          <button data-format="txt" class="export-opt w-full text-left px-3 py-2.5 flex items-center gap-2 text-sm text-slate-200 hover:bg-white/5 transition-colors">
            <span class="w-7 h-7 rounded-lg bg-slate-500/20 text-slate-300 grid place-items-center text-[10px] font-bold">TXT</span>
            <div class="flex-1">
              <p class="font-medium">Texto plano</p>
              <p class="text-[10px] text-slate-500">.txt</p>
            </div>
          </button>
          <button data-format="srt" class="export-opt w-full text-left px-3 py-2.5 flex items-center gap-2 text-sm text-slate-200 hover:bg-white/5 transition-colors border-t border-white/5">
            <span class="w-7 h-7 rounded-lg bg-brand-500/20 text-brand-300 grid place-items-center text-[10px] font-bold">SRT</span>
            <div class="flex-1">
              <p class="font-medium">Subtítulos</p>
              <p class="text-[10px] text-slate-500">.srt · con timestamps</p>
            </div>
          </button>
          <button data-format="vtt" class="export-opt w-full text-left px-3 py-2.5 flex items-center gap-2 text-sm text-slate-200 hover:bg-white/5 transition-colors border-t border-white/5">
            <span class="w-7 h-7 rounded-lg bg-accent-500/20 text-accent-300 grid place-items-center text-[10px] font-bold">VTT</span>
            <div class="flex-1">
              <p class="font-medium">WebVTT</p>
              <p class="text-[10px] text-slate-500">.vtt · HTML5 video</p>
            </div>
          </button>
          <button data-format="json" class="export-opt w-full text-left px-3 py-2.5 flex items-center gap-2 text-sm text-slate-200 hover:bg-white/5 transition-colors border-t border-white/5">
            <span class="w-7 h-7 rounded-lg bg-fuchsia-500/20 text-fuchsia-300 grid place-items-center text-[10px] font-bold">JSON</span>
            <div class="flex-1">
              <p class="font-medium">Estructurado</p>
              <p class="text-[10px] text-slate-500">.json · segmentos + tiempos</p>
            </div>
          </button>
        </div>
      </div>

      <button id="btn-back-done" type="button" class="btn-ghost text-sm flex-1 sm:flex-none">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="19 12 5 12"/><polyline points="12 19 5 12 12 5"/></svg>
        <span>MP3</span>
      </button>
      <button id="btn-again-2" type="button" class="btn-primary text-sm flex-1 sm:flex-none">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        <span>Nuevo</span>
      </button>
    </div>
  </div>

  <!-- Stage: ERROR -->
  <div data-stage="error" class="hidden">
    <div class="flex flex-col items-center text-center py-6">
      <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-2xl bg-rose-500/20 border border-rose-400/30 grid place-items-center mb-5">
        <svg class="w-8 h-8 sm:w-9 sm:h-9 text-rose-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      </div>
      <h3 class="text-xl sm:text-2xl font-bold text-white mb-2">Algo salió mal</h3>
      <p id="error-msg" class="text-rose-200/80 mb-6 max-w-md text-sm sm:text-base px-2">Error desconocido.</p>
      <button id="btn-retry" type="button" class="btn-primary">
        Intentar de nuevo
      </button>
    </div>
  </div>
</section>

<script>
  import { initConverter } from '../scripts/converter';
  initConverter();
</script>
