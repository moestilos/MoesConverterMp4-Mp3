---
interface Props {
  mode: 'login' | 'register';
}
const { mode } = Astro.props;
const isLogin = mode === 'login';
---

<div class="w-full max-w-md" data-auth-mode={mode}>
  <!-- Logo -->
  <div class="flex flex-col items-center mb-6 sm:mb-8">
    <a href="/" class="group flex items-center gap-2.5 mb-4" aria-label="Inicio">
      <span class="relative w-12 h-12 rounded-2xl
                   bg-gradient-to-br from-brand-500 via-accent-500 to-fuchsia-500
                   grid place-items-center
                   shadow-[0_10px_40px_-10px_rgba(124,58,237,0.6)]
                   transition-transform group-hover:scale-105">
        <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 20V4l6 8 6-8v16" />
        </svg>
      </span>
    </a>
    <h1 class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight text-center">
      {isLogin ? 'Bienvenido de vuelta' : 'Crea tu cuenta'}
    </h1>
    <p class="text-slate-400 text-sm mt-1.5 text-center px-2">
      {isLogin
        ? 'Entra para convertir y transcribir audio.'
        : 'Gratis · sin tarjeta · sin marcas de agua.'}
    </p>
  </div>

  <!-- Card -->
  <div class="glass rounded-3xl p-5 sm:p-8 shadow-card">
    <!-- Alert -->
    <div id="form-error"
         class="hidden items-start gap-2 p-3 mb-4 rounded-xl
                bg-rose-500/10 border border-rose-400/30 text-rose-200 text-sm">
      <svg class="w-4 h-4 mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <span id="form-error-msg">Error</span>
    </div>

    <form id="auth-form" class="space-y-4" novalidate>
      {!isLogin && (
        <div>
          <label for="email" class="block text-xs font-medium uppercase tracking-wider text-slate-400 mb-1.5">
            Correo
          </label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </span>
            <input id="email" name="email" type="email" required
              autocomplete="email" autocapitalize="none" autocorrect="off" spellcheck="false"
              placeholder="tu@correo.com"
              class="w-full bg-white/[0.03] border border-white/10 rounded-xl pl-10 pr-4 py-3 text-white placeholder-slate-600 outline-none focus:border-accent-400/60 focus:ring-2 focus:ring-accent-500/20 transition-all" />
          </div>
        </div>
      )}

      <div>
        <label for="identifier" class="block text-xs font-medium uppercase tracking-wider text-slate-400 mb-1.5">
          {isLogin ? 'Email o username' : 'Username'}
        </label>
        <div class="relative">
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          </span>
          <input id="identifier" name="identifier" type="text" required
            autocomplete={isLogin ? 'username' : 'username'}
            autocapitalize="none" autocorrect="off" spellcheck="false"
            minlength={isLogin ? undefined : 3} maxlength={isLogin ? undefined : 32}
            pattern={isLogin ? undefined : '[a-zA-Z0-9_.\\-]+'}
            placeholder={isLogin ? 'momo o tu@correo.com' : 'tu_username'}
            class="w-full bg-white/[0.03] border border-white/10 rounded-xl pl-10 pr-4 py-3 text-white placeholder-slate-600 outline-none focus:border-accent-400/60 focus:ring-2 focus:ring-accent-500/20 transition-all" />
        </div>
        {!isLogin && (
          <p class="text-xs text-slate-500 mt-1.5 pl-1">3-32 caracteres: letras, números, punto, guion</p>
        )}
      </div>

      <div>
        <div class="flex items-center justify-between mb-1.5">
          <label for="password" class="block text-xs font-medium uppercase tracking-wider text-slate-400">
            Contraseña
          </label>
          {!isLogin && (
            <span class="text-xs text-slate-500">Mín. 6 caracteres</span>
          )}
        </div>
        <div class="relative">
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </span>
          <input id="password" name="password" type="password" required
            minlength={isLogin ? undefined : 6}
            autocomplete={isLogin ? 'current-password' : 'new-password'}
            placeholder="••••••••"
            class="w-full bg-white/[0.03] border border-white/10 rounded-xl pl-10 pr-11 py-3 text-white placeholder-slate-600 outline-none focus:border-accent-400/60 focus:ring-2 focus:ring-accent-500/20 transition-all" />
          <button type="button" id="toggle-pw"
                  aria-label="Mostrar u ocultar contraseña"
                  class="absolute right-2 top-1/2 -translate-y-1/2 w-9 h-9 grid place-items-center rounded-lg text-slate-400 hover:text-white hover:bg-white/5 transition-colors">
            <svg id="eye-on" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
            <svg id="eye-off" class="hidden w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
              <line x1="1" y1="1" x2="23" y2="23"/>
            </svg>
          </button>
        </div>
      </div>

      <button id="submit-btn" type="submit" class="btn-primary w-full mt-2">
        <span id="submit-label" class="flex items-center gap-2">
          {isLogin ? 'Entrar' : 'Crear cuenta'}
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </span>
        <span id="submit-spinner" class="hidden items-center gap-2">
          <svg class="w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
          </svg>
          <span>{isLogin ? 'Entrando…' : 'Creando…'}</span>
        </span>
      </button>
    </form>
  </div>

  <!-- Footer switch -->
  <p class="text-center text-sm text-slate-400 mt-6">
    {isLogin ? (
      <>¿Sin cuenta? <a href="/register" class="text-accent-400 hover:text-accent-300 font-medium underline-offset-4 hover:underline">Crea una gratis</a></>
    ) : (
      <>¿Ya tienes cuenta? <a href="/login" class="text-accent-400 hover:text-accent-300 font-medium underline-offset-4 hover:underline">Entra</a></>
    )}
  </p>
</div>

<script>
  import { initAuthForm } from '../scripts/authForm';
  const root = document.querySelector('[data-auth-mode]');
  const mode = root?.getAttribute('data-auth-mode') as 'login' | 'register';
  if (mode) initAuthForm(mode);
</script>
