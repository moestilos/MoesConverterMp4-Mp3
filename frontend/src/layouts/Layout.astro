---
import '../styles/global.css';
import { pwaInfo } from 'virtual:pwa-info';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'MoesConverter · MP4 → MP3',
  description = 'Convierte MP4 a MP3 y transcribe audio a texto. Rápido, privado, sin registro.',
} = Astro.props;
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#07070b" />
    <meta name="color-scheme" content="dark" />

    <!-- iOS / Safari PWA -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="MoesConverter" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    />
    {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-[#07070b] text-slate-100 antialiased font-sans overflow-x-hidden">
    <div class="bg-aurora" aria-hidden="true"></div>
    <div class="bg-grid" aria-hidden="true"></div>
    <slot />

    <!-- Toast container -->
    <div id="toast-root"
         class="fixed top-2 sm:top-auto sm:bottom-6 inset-x-0 sm:inset-x-auto sm:right-6 z-50
                flex flex-col items-center sm:items-end gap-2 px-4 sm:px-0 pointer-events-none"
         style="padding-top: env(safe-area-inset-top);"></div>

    <script>
      import { registerSW } from 'virtual:pwa-register';
      import { warmupBackend } from '../scripts/auth';
      registerSW({ immediate: true });
      // Despierta backend al cargar cualquier página (Render free cold start).
      warmupBackend();
    </script>
  </body>
</html>
