---
import Layout from '../layouts/Layout.astro';
import AuthNav from '../components/AuthNav.astro';
import Converter from '../components/Converter.astro';
---

<Layout>
  <AuthNav />
  <main class="relative max-w-4xl mx-auto px-4 sm:px-6 md:px-8 pt-20 sm:pt-24 pb-16 sm:pb-24">
    <header class="text-center mb-10 sm:mb-14 md:mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full
                  text-xs font-medium text-slate-300
                  bg-white/5 border border-white/10 mb-5 sm:mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
        MP4 → MP3 + transcripción offline
      </div>

      <h1 class="text-3xl sm:text-5xl md:text-6xl font-extrabold tracking-tight leading-[1.05] mb-4 sm:mb-5">
        <span class="text-white">Extrae audio de tu video</span><br/>
        <span class="text-gradient">y conviértelo en texto.</span>
      </h1>

      <p class="text-slate-400 text-base sm:text-lg max-w-2xl mx-auto px-2">
        Sube un MP4, descarga un MP3 de alta calidad y, si quieres, transcríbelo
        a texto con Whisper ejecutándose <strong class="text-slate-200">en tu propio dispositivo</strong>.
        Sin marcas de agua, sin anuncios.
      </p>
    </header>

    <Converter />

    <section class="mt-12 sm:mt-20 grid grid-cols-1 md:grid-cols-3 gap-3 sm:gap-4 text-sm">
      <div class="glass rounded-2xl p-5">
        <div class="w-10 h-10 rounded-xl bg-brand-500/20 grid place-items-center mb-3">
          <svg class="w-5 h-5 text-brand-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2 3 14h7l-1 8 10-12h-7z"/></svg>
        </div>
        <p class="text-white font-semibold mb-1">FFmpeg real</p>
        <p class="text-slate-400">Procesado nativo en servidor con libmp3lame a 192 kbps.</p>
      </div>
      <div class="glass rounded-2xl p-5">
        <div class="w-10 h-10 rounded-xl bg-accent-500/20 grid place-items-center mb-3">
          <svg class="w-5 h-5 text-accent-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <p class="text-white font-semibold mb-1">Whisper local</p>
        <p class="text-slate-400">Transcripción 100% en tu navegador. El audio nunca abandona tu dispositivo.</p>
      </div>
      <div class="glass rounded-2xl p-5">
        <div class="w-10 h-10 rounded-xl bg-emerald-500/20 grid place-items-center mb-3">
          <svg class="w-5 h-5 text-emerald-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2h4l2 4-2 4h-4l-2-4z"/><path d="M4 14h16v6H4z"/></svg>
        </div>
        <p class="text-white font-semibold mb-1">Instalable</p>
        <p class="text-slate-400">Añádela a tu pantalla de inicio en iPhone, Android o PC. Funciona como app.</p>
      </div>
    </section>

    <footer class="mt-16 sm:mt-20 text-center text-xs sm:text-sm text-slate-500 px-2">
      <p>
        Construido con <span class="text-slate-300">Astro</span> ·
        <span class="text-slate-300">Tailwind</span> ·
        <span class="text-slate-300">Express</span> ·
        <span class="text-slate-300">FFmpeg</span> ·
        <span class="text-slate-300">Transformers.js</span>
      </p>
    </footer>
  </main>
</Layout>

<script>
  import { requireAuth, trackVisit } from '../scripts/auth';
  const user = requireAuth('/login?next=/');
  if (user) {
    trackVisit();
  }
</script>
