---
import Layout from '../layouts/Layout.astro';
import Converter from '../components/Converter.astro';
---

<Layout>
  <main class="relative max-w-4xl mx-auto px-5 sm:px-8 pt-16 pb-24">
    <header class="text-center mb-12 sm:mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full
                  text-xs font-medium text-slate-300
                  bg-white/5 border border-white/10 mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
        Convierte MP4 a MP3 en segundos
      </div>

      <h1 class="text-4xl sm:text-6xl font-extrabold tracking-tight leading-[1.05] mb-5">
        <span class="text-white">Extrae audio de tu video,</span><br/>
        <span class="text-gradient">rápido y privado.</span>
      </h1>

      <p class="text-slate-400 text-lg max-w-2xl mx-auto">
        Sube un MP4 y descarga un MP3 de alta calidad en segundos.
        Sin registros, sin marcas de agua, sin anuncios.
      </p>
    </header>

    <Converter />

    <section class="mt-20 grid grid-cols-1 md:grid-cols-3 gap-4 text-sm">
      <div class="glass rounded-2xl p-5">
        <div class="w-10 h-10 rounded-xl bg-brand-500/20 grid place-items-center mb-3">
          <svg class="w-5 h-5 text-brand-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2 3 14h7l-1 8 10-12h-7z"/></svg>
        </div>
        <p class="text-white font-semibold mb-1">FFmpeg real</p>
        <p class="text-slate-400">Procesado nativo en servidor con libmp3lame a 192 kbps.</p>
      </div>
      <div class="glass rounded-2xl p-5">
        <div class="w-10 h-10 rounded-xl bg-accent-500/20 grid place-items-center mb-3">
          <svg class="w-5 h-5 text-accent-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <p class="text-white font-semibold mb-1">Archivos efímeros</p>
        <p class="text-slate-400">Se eliminan automáticamente tras la descarga o a los 15 min.</p>
      </div>
      <div class="glass rounded-2xl p-5">
        <div class="w-10 h-10 rounded-xl bg-emerald-500/20 grid place-items-center mb-3">
          <svg class="w-5 h-5 text-emerald-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg>
        </div>
        <p class="text-white font-semibold mb-1">Progreso real</p>
        <p class="text-slate-400">Server-Sent Events transmiten el progreso exacto de FFmpeg.</p>
      </div>
    </section>

    <footer class="mt-20 text-center text-sm text-slate-500">
      <p>
        Construido con <span class="text-slate-300">Astro</span> ·
        <span class="text-slate-300">Tailwind</span> ·
        <span class="text-slate-300">Express</span> ·
        <span class="text-slate-300">FFmpeg</span>
      </p>
    </footer>
  </main>
</Layout>
