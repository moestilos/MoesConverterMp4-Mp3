---
import Layout from '../layouts/Layout.astro';
import AuthNav from '../components/AuthNav.astro';
---

<Layout title="Crear cuenta · MoesConverter">
  <AuthNav />
  <main class="min-h-screen flex items-center justify-center px-4 pt-20 pb-10">
    <div class="w-full max-w-md glass rounded-3xl p-6 sm:p-8 shadow-card">
      <h1 class="text-2xl sm:text-3xl font-bold text-white mb-2">Crear cuenta</h1>
      <p class="text-slate-400 text-sm mb-6">
        ¿Ya tienes una? <a href="/login" class="text-accent-400 hover:underline">Entra</a>.
      </p>

      <form id="register-form" class="space-y-4">
        <div>
          <label for="email" class="block text-sm text-slate-300 mb-1">Email</label>
          <input id="email" name="email" type="email" required autocomplete="email"
            class="w-full bg-white/[0.03] border border-white/10 rounded-xl px-4 py-3 text-white outline-none focus:border-accent-400/60" />
        </div>
        <div>
          <label for="username" class="block text-sm text-slate-300 mb-1">Username</label>
          <input id="username" name="username" type="text" required minlength="3" maxlength="32"
            pattern="[a-zA-Z0-9_.\-]+" autocomplete="username"
            class="w-full bg-white/[0.03] border border-white/10 rounded-xl px-4 py-3 text-white outline-none focus:border-accent-400/60" />
          <p class="text-xs text-slate-500 mt-1">3-32 caracteres: letras, números, punto, guion, bajo</p>
        </div>
        <div>
          <label for="password" class="block text-sm text-slate-300 mb-1">Contraseña</label>
          <input id="password" name="password" type="password" required minlength="6" autocomplete="new-password"
            class="w-full bg-white/[0.03] border border-white/10 rounded-xl px-4 py-3 text-white outline-none focus:border-accent-400/60" />
          <p class="text-xs text-slate-500 mt-1">Mínimo 6 caracteres</p>
        </div>
        <p id="register-error" class="text-rose-300 text-sm hidden"></p>
        <button type="submit" class="btn-primary w-full">Crear cuenta</button>
      </form>
    </div>
  </main>
</Layout>

<script>
  import { apiFetch, setToken, setUser } from '../scripts/auth';
  const form = document.getElementById('register-form') as HTMLFormElement | null;
  const err = document.getElementById('register-error');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    err?.classList.add('hidden');
    const fd = new FormData(form);
    try {
      const res = await apiFetch('/auth/register', {
        method: 'POST',
        body: JSON.stringify({
          email: String(fd.get('email') ?? ''),
          username: String(fd.get('username') ?? ''),
          password: String(fd.get('password') ?? ''),
        }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data?.error ?? 'Error al registrarse');
      setToken(data.token);
      setUser(data.user);
      window.location.href = '/';
    } catch (e) {
      if (err) {
        err.textContent = (e as Error).message;
        err.classList.remove('hidden');
      }
    }
  });
</script>
